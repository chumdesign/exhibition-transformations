---
const { lang = 'uk' } = Astro.props;

// Translate mappings — техніка/матеріал
const dictionary: Record<string, string> = {
  "текстильний колаж": "textile collage",
  "змішана техніка": "mixed media",
  "тоноване дерево": "tinted wood",
  "артоб_єкт": "art object",
  "полотно": "canvas",
  "олія": "oil",
  "папір": "paper",
  "акварель": "watercolor",
  "акрил": "acrylic",
  "олівець": "pencil",
  "дерево": "wood",
  "метал": "metal",
  "офорт": "etching",
  "травлення": "engraving",
  "текстиль": "textile",
  "скло": "glass",
  "туш": "ink",
  "перо": "pen",
  "двп": "fiberboard",
  "левкас": "gesso",
  "жвт": "painting",
  "емаль": "enamel",
  "темпера": "tempera",
  "фанера": "plywood",
  "серія": "series",
  "цивілізація": "Civilization",
  "з триптиха": "from the triptych",
  "см": "cm",
  "sm": "cm"
};

// Транслітерація українських символів → латиниця
const translitMap: Record<string, string> = {
  "а": "a", "б": "b", "в": "v", "г": "h", "ґ": "g", "д": "d", "е": "e", "є": "ye",
  "ж": "zh", "з": "z", "и": "y", "і": "i", "ї": "yi", "й": "i", "к": "k", "л": "l",
  "м": "m", "н": "n", "о": "o", "п": "p", "р": "r", "с": "s", "т": "t", "у": "u",
  "ф": "f", "х": "kh", "ц": "ts", "ч": "ch", "ш": "sh", "щ": "shch", "ь": "", "ю": "iu", "я": "ia",
  "А": "A", "Б": "B", "В": "V", "Г": "H", "Ґ": "G", "Д": "D", "Е": "E", "Є": "Ye",
  "Ж": "Zh", "З": "Z", "И": "Y", "І": "I", "Ї": "Yi", "Й": "Y", "К": "K", "Л": "L",
  "М": "M", "Н": "N", "О": "O", "П": "P", "Р": "R", "С": "S", "Т": "T", "У": "U",
  "Ф": "F", "Х": "Kh", "Ц": "Ts", "Ч": "Ch", "Ш": "Sh", "Щ": "Shch", "Ь": "", "Ю": "Yu", "Я": "Ya",
  "'": "", "'": ""
};

const transliterate = (text: string): string => {
  if (lang === 'uk') return text;
  return text.split('').map(char => translitMap[char] ?? char).join('');
};

const translateDetails = (details: string) => {
   if (lang === 'uk') return details;
   let enDetails = details.toLowerCase();
   for (const [ua, en] of Object.entries(dictionary)) {
     enDetails = enDetails.replace(new RegExp(ua, 'g'), en);
   }
   return enDetails;
}

const rawImages = import.meta.glob('../assets/images/artwork/*.webp', { eager: true });
// HD-версії з тієї ж папки artwork_hd/ (якщо є)
const rawHdImages = import.meta.glob('../assets/images/artwork_hd/*.webp', { eager: true });
const artworks = Object.entries(rawImages).map(([path, img]: [string, any]) => {
  const filename = path.split('/').pop() || '';
  const parts = filename.split('_');
  
  let authorHtml = '';
  let titleHtml = '';
  let detailsHtml = '';
  let fullCaptionHtml = '';
  
  if (parts.length >= 3) {
    let authorRaw = parts[0].replace(/,\s*$/, '').trim();
    let titleRaw = parts[1].trim();
    if (titleRaw.length > 0) {
      titleRaw = titleRaw.charAt(0).toUpperCase() + titleRaw.slice(1);
    }
    const details = parts.slice(2).join('_').replace(/\.webp$/, '').replace(/^,\s*/, '').trim();

    // Замінюємо деякі специфічні слова в імені/назві перед транслітерацією
    if (lang !== 'uk') {
      authorRaw = authorRaw.toLowerCase().replace('з триптиха', 'from the triptych');
      titleRaw = titleRaw.replace(/Цивілізація/gi, 'Civilization');
    }

    // Транслітеруємо автора і назву для EN
    const author = transliterate(authorRaw);
    const title = transliterate(titleRaw);
    
    authorHtml = author;
    titleHtml = title;
    detailsHtml = translateDetails(details);
    fullCaptionHtml = `<span class="font-bold block mb-2 text-lg tracking-wide md:text-xl"><span class="uppercase">${author}</span> — «${title}»</span><span class="font-light text-sm md:text-base opacity-80">${detailsHtml}</span>`;
  } else {
    authorHtml = transliterate(filename.replace('.webp', ''));
    fullCaptionHtml = `<span class="font-bold block mb-1 text-lg uppercase tracking-wide md:text-xl">${authorHtml}</span>`;
  }

  // Шукаємо HD-версію: той самий filename, але в папці artwork_hd/
  const hdPath = path.replace('/artwork/', '/artwork_hd/');
  const hdImg = rawHdImages[hdPath] as any;
  const hdSrc = hdImg?.default?.src ?? null;

  return {
    src: img.default.src,
    hdSrc,
    author: authorHtml,
    title: titleHtml,
    details: detailsHtml,
    caption: fullCaptionHtml,
    width: img.default.width || 800,
    height: img.default.height || 600
  };
}).sort((a, b) => {
  const isAShulyak = a.author.includes('Шуляк') || a.author.includes('Shulyak');
  const isBShulyak = b.author.includes('Шуляк') || b.author.includes('Shulyak');
  if (isAShulyak && !isBShulyak) return -1;
  if (!isAShulyak && isBShulyak) return 1;

  const isATkachenko = a.author.includes('Ткаченко') || a.author.includes('Tkachenko');
  const isBTkachenko = b.author.includes('Ткаченко') || b.author.includes('Tkachenko');
  if (isATkachenko && !isBTkachenko) return -1;
  if (!isATkachenko && isBTkachenko) return 1;

  return a.author.localeCompare(b.author);
});

const tHeading = lang === 'uk' ? 'Картини' : 'Artworks';
---
<section id="artworks" class="pt-16 pb-24 md:py-32 bg-gray-50">
  <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12 md:mb-16 block">
      <h2 class="text-2xl md:text-3xl font-bold uppercase tracking-widest text-gray-900 inline-block relative">
        {tHeading}
        <div class="absolute w-1/2 h-1 bg-gray-900 left-1/4 -bottom-4"></div>
      </h2>
    </div>

    <!-- Masonry Layout using CSS columns -->
    <div class="columns-2 md:columns-3 lg:columns-4 xl:columns-5 gap-3 sm:gap-6 space-y-3 sm:space-y-6">
      {artworks.map(art => (
        <div
          class="break-inside-avoid relative group cursor-pointer"
          data-lightbox={art.src}
          data-lightbox-hd={art.hdSrc}
          data-caption={art.caption}
        >
          <img 
            src={art.src} 
            alt={art.title || art.author} 
            loading="lazy" 
            class="w-full h-auto rounded-sm shadow-md transition-shadow duration-300 group-hover:shadow-2xl"
            width={art.width}
            height={art.height}
          />
          <div class="absolute inset-0 bg-white/85 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col items-center justify-center p-4 text-center backdrop-blur-sm">
             <span class="text-gray-900 font-bold tracking-wide text-xs sm:text-sm md:text-base leading-relaxed mb-2 drop-shadow-sm"><span class="uppercase">{art.author}</span> <br/> {art.title ? <span class="normal-case tracking-normal font-semibold">«{art.title}»</span> : ''}</span>
             {art.details && <span class="text-gray-600 font-light text-[0.65rem] sm:text-xs md:text-sm tracking-wide leading-tight">{art.details}</span>}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>


<!-- Lightbox -->
<div id="lightbox" class="fixed inset-0 z-[100] bg-black/95 hidden flex-col items-center justify-center backdrop-blur-md opacity-0 transition-opacity duration-300" style="touch-action: none;">
  
  <!-- Хрестик -->
  <button id="lightbox-close" class="fixed top-3 right-3 text-white/70 hover:text-white transition-colors cursor-pointer z-[110]" aria-label="Close">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg>
  </button>

  <!-- Стрілка назад -->
  <button id="lightbox-prev" class="fixed left-2 top-1/2 -translate-y-1/2 text-white/50 hover:text-white transition-colors cursor-pointer z-[110] p-2" aria-label="Previous">
    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5"></path></svg>
  </button>

  <!-- Стрілка вперед -->
  <button id="lightbox-next" class="fixed right-2 top-1/2 -translate-y-1/2 text-white/50 hover:text-white transition-colors cursor-pointer z-[110] p-2" aria-label="Next">
    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"></path></svg>
  </button>

  <!-- Лічильник X / N -->
  <div id="lightbox-counter" class="fixed bottom-4 left-1/2 -translate-x-1/2 text-white/60 text-sm bg-black/40 px-3 py-1 rounded-full z-[110] select-none pointer-events-none">
    1 / 1
  </div>

  <!-- Центрований контент (без scroll — зум через transform) -->
  <div id="lightbox-inner" class="flex flex-col items-center justify-center w-full h-full overflow-hidden px-12 py-16">
    <!-- style="transform-origin: center" — потрібен для правильного zoom -->
    <img
      id="lightbox-img"
      src=""
      alt=""
      class="max-w-[88vw] max-h-[78vh] object-contain shadow-2xl select-none"
      style="transform-origin: center; transition: transform 0.12s ease; will-change: transform;"
    />
    <div id="lightbox-caption" class="text-white mt-4 text-center max-w-[88vw] opacity-90"></div>
  </div>
</div>

<script>
  // ─── DOM refs ───────────────────────────────────────────────────────────────
  const galleryItems  = Array.from(document.querySelectorAll('[data-lightbox]'));
  const lightbox      = document.getElementById('lightbox')!;
  const lightboxImg   = document.getElementById('lightbox-img') as HTMLImageElement;
  const lightboxCap   = document.getElementById('lightbox-caption')!;
  const lightboxClose = document.getElementById('lightbox-close')!;
  const lightboxPrev  = document.getElementById('lightbox-prev')!;
  const lightboxNext  = document.getElementById('lightbox-next')!;
  const lightboxCnt   = document.getElementById('lightbox-counter')!;

  // ─── Стан навігації ─────────────────────────────────────────────────────────
  let currentIndex = 0;
  let hdAbortIndex = -1;

  // ─── Стан zoom / pan ────────────────────────────────────────────────────────
  let zoomLevel = 1;
  let panX = 0, panY = 0;
  const MAX_ZOOM  = 3;
  const ZOOM_STEP = 0.5;

  const applyTransform = () => {
    lightboxImg.style.transform = `scale(${zoomLevel}) translate(${panX / zoomLevel}px, ${panY / zoomLevel}px)`;
    lightboxImg.style.cursor = zoomLevel > 1 ? 'grab' : 'zoom-in';
  };

  const resetZoom = () => { zoomLevel = 1; panX = panY = 0; applyTransform(); };

  // ─── Лічильник ──────────────────────────────────────────────────────────────
  const updateCounter = () => {
    lightboxCnt.textContent = `${currentIndex + 1} / ${galleryItems.length}`;
  };

  // ─── HD lazy-load ─────────────────────────────────────────────────────────
  const loadHD = (index: number) => {
    const el = galleryItems[index] as HTMLElement;
    const hd = el.dataset.lightboxHd;
    if (!hd || hd === 'null') return;
    hdAbortIndex = index;
    const loader = new Image();
    loader.onload = () => {
      if (hdAbortIndex === index && currentIndex === index) {
        lightboxImg.src = hd;
      }
    };
    loader.src = hd;
  };

  // ─── Відкрити / закрити ──────────────────────────────────────────────────
  const openLightbox = (index: number) => {
    currentIndex = index;
    resetZoom();
    const el      = galleryItems[index] as HTMLElement;
    const src     = el.dataset.lightbox!;
    const caption = el.dataset.caption || '';
    lightboxImg.src       = src;
    lightboxCap.innerHTML = caption;
    updateCounter();
    lightbox.classList.remove('hidden');
    lightbox.classList.add('flex');
    setTimeout(() => {
      lightbox.classList.remove('opacity-0');
      lightbox.classList.add('opacity-100');
    }, 10);
    document.body.style.overflow = 'hidden';
    loadHD(index);
  };

  const closeLightbox = () => {
    lightbox.classList.replace('opacity-100', 'opacity-0');
    setTimeout(() => {
      lightbox.classList.add('hidden');
      lightbox.classList.remove('flex');
      lightboxImg.src = '';
      resetZoom();
    }, 300);
    document.body.style.overflow = '';
    hdAbortIndex = -1;
  };

  const showPrev = () => openLightbox((currentIndex - 1 + galleryItems.length) % galleryItems.length);
  const showNext = () => openLightbox((currentIndex + 1) % galleryItems.length);

  // ─── Кліки по мініатюрах ────────────────────────────────────────────────
  galleryItems.forEach((el, i) => el.addEventListener('click', () => openLightbox(i)));

  // ─── Кнопки ─────────────────────────────────────────────────────────────
  lightboxClose.addEventListener('click', closeLightbox);
  lightboxPrev.addEventListener('click', (e) => { e.stopPropagation(); showPrev(); });
  lightboxNext.addEventListener('click', (e) => { e.stopPropagation(); showNext(); });

  // Клік по фону
  lightbox.addEventListener('click', (e) => {
    const t = e.target as HTMLElement;
    const inside = t.closest('#lightbox-img, #lightbox-caption, #lightbox-close, #lightbox-prev, #lightbox-next, #lightbox-counter');
    if (!inside) closeLightbox();
  });

  // ─── Клавіатура ─────────────────────────────────────────────────────────
  document.addEventListener('keydown', (e) => {
    if (lightbox.classList.contains('hidden')) return;
    if (e.key === 'Escape')      closeLightbox();
    if (e.key === 'ArrowLeft')   showPrev();
    if (e.key === 'ArrowRight')  showNext();
    if (e.key === '+' || e.key === '=') {
      zoomLevel = Math.min(MAX_ZOOM, zoomLevel + ZOOM_STEP); applyTransform();
    }
    if (e.key === '-') {
      zoomLevel = Math.max(1, zoomLevel - ZOOM_STEP);
      if (zoomLevel === 1) { panX = panY = 0; }
      applyTransform();
    }
  });

  // ─── Zoom: колесо миші ───────────────────────────────────────────────────
  lightboxImg.addEventListener('wheel', (e) => {
    e.preventDefault();
    e.stopPropagation();
    const delta = e.deltaY > 0 ? -ZOOM_STEP : ZOOM_STEP;
    zoomLevel = Math.min(MAX_ZOOM, Math.max(1, zoomLevel + delta));
    if (zoomLevel === 1) { panX = panY = 0; }
    applyTransform();
  }, { passive: false });

  // ─── Zoom: подвійний клік ────────────────────────────────────────────────
  lightboxImg.addEventListener('dblclick', (e) => {
    e.stopPropagation();
    if (zoomLevel > 1) { zoomLevel = 1; panX = panY = 0; }
    else               { zoomLevel = 2; }
    applyTransform();
  });

  // ─── Pan: мишею ─────────────────────────────────────────────────────────
  let isDragging = false;
  let dragSX = 0, dragSY = 0, dragSPX = 0, dragSPY = 0;

  lightboxImg.addEventListener('mousedown', (e) => {
    if (zoomLevel > 1) {
      e.preventDefault();
      isDragging = true;
      dragSX = e.clientX; dragSY = e.clientY;
      dragSPX = panX;     dragSPY = panY;
      lightboxImg.style.cursor = 'grabbing';
    }
  });
  document.addEventListener('mousemove', (e) => {
    if (!isDragging || zoomLevel <= 1) return;
    const limit = 400 * zoomLevel;
    panX = Math.max(-limit, Math.min(limit, dragSPX + (e.clientX - dragSX)));
    panY = Math.max(-limit, Math.min(limit, dragSPY + (e.clientY - dragSY)));
    applyTransform();
  });
  document.addEventListener('mouseup', () => {
    isDragging = false;
    if (zoomLevel > 1) lightboxImg.style.cursor = 'grab';
  });

  // ─── Touch: swipe + pinch-zoom + pan + double-tap ────────────────────────
  let touchStartX = 0, touchStartY = 0;
  let initDist = 0, initZoom = 1, isPinching = false;
  let lastPanOX = 0, lastPanOY = 0;
  let lastTap = 0;

  lightbox.addEventListener('touchstart', (e) => {
    if (e.touches.length === 2) {
      isPinching = true;
      initDist   = Math.hypot(
        e.touches[0].pageX - e.touches[1].pageX,
        e.touches[0].pageY - e.touches[1].pageY
      );
      initZoom = zoomLevel;
    } else if (e.touches.length === 1) {
      touchStartX = e.touches[0].clientX;
      touchStartY = e.touches[0].clientY;
      if (zoomLevel > 1) {
        lastPanOX = e.touches[0].clientX - panX;
        lastPanOY = e.touches[0].clientY - panY;
      }
      // Double-tap
      const now = Date.now();
      if (now - lastTap < 300) {
        e.preventDefault();
        if (zoomLevel > 1) { zoomLevel = 1; panX = panY = 0; }
        else               { zoomLevel = 2; }
        applyTransform();
      }
      lastTap = now;
    }
  }, { passive: false });

  lightbox.addEventListener('touchmove', (e) => {
    if (e.touches.length === 2 && isPinching) {
      e.preventDefault();
      const dist = Math.hypot(
        e.touches[0].pageX - e.touches[1].pageX,
        e.touches[0].pageY - e.touches[1].pageY
      );
      zoomLevel = Math.min(MAX_ZOOM, Math.max(1, initZoom * (dist / initDist)));
      applyTransform();
    } else if (e.touches.length === 1 && zoomLevel > 1) {
      e.preventDefault();
      const limit = 400 * zoomLevel;
      panX = Math.max(-limit, Math.min(limit, e.touches[0].clientX - lastPanOX));
      panY = Math.max(-limit, Math.min(limit, e.touches[0].clientY - lastPanOY));
      applyTransform();
    }
  }, { passive: false });

  lightbox.addEventListener('touchend', (e) => {
    if (e.touches.length < 2) isPinching = false;
    // Swipe тільки при zoom 1×
    if (zoomLevel === 1 && e.changedTouches.length > 0) {
      const dx = e.changedTouches[0].clientX - touchStartX;
      const dy = e.changedTouches[0].clientY - touchStartY;
      if (Math.abs(dx) > 50 && Math.abs(dx) > Math.abs(dy)) {
        if (dx < 0) showNext();
        else        showPrev();
      }
    }
  }, { passive: true });
</script>

