---
const { lang = 'uk' } = Astro.props;

const allParticipants = [
  "Інна Пантелемонова, Київ",
  "Павло Македонський, Київ",
  "Ксенія Осадчук, Київ",
  "Денис Коробка, Київ",
  "Анна Крюкова, Київ",
  "Микола Цимбал, Київ",
  "Ярослав Ткаченко, Трипілля",
  "Василь Змієвець, Львів",
  "Іван Цап’як, Львів",
  "Ілона Шимчиць, Мушкатівка",
  "Ігор Панейко, Ужгород",
  "Антон Ковач, Ужгород",
  "Олексій Малік, Одеса",
  "Олена Новак, Одеса",
  "Максим Юхно, Полтава",
  "Кристина Сіренко, Полтава",
  "Андрій Гіль, Полтава",
  "Денис Страшко, Полтава",
  "Лілія Шабаліна, Полтава",
  "Наталя Дегтяр, Полтава",
  "Тетяна Шуляк, Кременчук",
  "Інна Мосієнко, Кременчук",
  "Олег Мосієнко, Кременчук",
  "Ольга Гриценко, Кременчук",
  "Анжела Голишкіна, Кременчук",
  "Олексій Рубанов, Кременчук",
  "Марта Мак, Рівне",
  "Марія Некрасова, Кропивницький",
  "Марина Руденко, Харків",
  "Геннадій Корнієнко, Харків",
  "Зінаїда Власенко, Горішні Плавні",
  "Віктор Чумаченко, Світловодськ",
  "Ната Бойчук, Світловодськ",
  "Володимир Товкайло, Світловодськ",
  "Vika Krutko, France",
  "Daria Most, Italy",
  "Hanna Nistrom, Sweden",
  "Irina Aleksandrova, Sweden",
  "Oleg Lipchenko, Canada",
  "Evaldas Grinius, Lithuania",
  "Monika Veckiene, Lithuania",
  "Terese Krutulyte, Lithuania",
  "Saule Gylys, Lithuania",
  "Vilija Murauskaite-Raguckiene, Lithuania"
];
const tTitle = lang === 'uk' ? 'Учасники' : 'Participants';

const citiesTranslation: Record<string, string> = {
  "Київ": "Kyiv", "Трипілля": "Trypillia", "Львів": "Lviv",
  "Мушкатівка": "Mushkativka", "Ужгород": "Uzhhorod", "Одеса": "Odesa",
  "Полтава": "Poltava", "Кременчук": "Kremenchuk", "Рівне": "Rivne",
  "Кропивницький": "Kropyvnytskyi", "Харків": "Kharkiv", "Горішні Плавні": "Horishni Plavni",
  "Світловодськ": "Svitlovodsk"
};

const translitMap: Record<string, string> = {
  "а": "a", "б": "b", "в": "v", "г": "h", "ґ": "g", "д": "d", "е": "e", "є": "ye", "ж": "zh", "з": "z", "и": "y", "і": "i", "ї": "yi", "й": "i", "к": "k", "л": "l", "м": "m", "н": "n", "о": "o", "п": "p", "р": "r", "с": "s", "т": "t", "у": "u", "ф": "f", "х": "kh", "ц": "ts", "ч": "ch", "ш": "sh", "щ": "shch", "ь": "", "ю": "iu", "я": "ia",
  "А": "A", "Б": "B", "В": "V", "Г": "H", "Ґ": "G", "Д": "D", "Е": "E", "Є": "Ye", "Ж": "Zh", "З": "Z", "И": "Y", "І": "I", "Ї": "Yi", "Й": "Y", "К": "K", "Л": "L", "М": "M", "Н": "N", "О": "O", "П": "P", "Р": "R", "С": "S", "Т": "T", "У": "U", "Ф": "F", "Х": "Kh", "Ц": "Ts", "Ч": "Ch", "Ш": "Sh", "Щ": "Shch", "Ь": "", "Ю": "Yu", "Я": "Ya", "’": ""
};
const transliterate = (text: string) => {
  if (lang === 'uk') return text;
  return text.split('').map(char => translitMap[char] ?? char).join('');
};

---
<section id="participants" class="pt-16 pb-24 md:py-32 bg-white">
  <div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12 md:mb-16 block">
      <h2 class="text-2xl md:text-3xl font-bold uppercase tracking-widest text-gray-900 inline-block relative">
        {tTitle}
        <div class="absolute w-1/2 h-1 bg-gray-900 left-1/4 -bottom-4"></div>
      </h2>
    </div>

    <!-- Responsive Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-x-8 lg:gap-x-12 gap-y-1 sm:gap-y-1.5">
      {allParticipants.map(p => {
        const parts = p.split(', ');
        const name = transliterate(parts[0]);
        const city = parts[1] ? (lang === 'en' && citiesTranslation[parts[1]] ? citiesTranslation[parts[1]] : parts[1]) : '';
        return (
          <div class="leading-[1] md:leading-[1.1]">
            <span class="text-gray-900 font-semibold text-sm tracking-wide">{name}</span>
            {city && <span class="text-gray-400 font-light text-xs ml-2">{city}</span>}
          </div>
        )
      })}
    </div>
  </div>
</section>
